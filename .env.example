# ============ BACKEND (Render) environment variables ============

# --- Meta / WhatsApp Cloud API ---
# From developers.facebook.com > your app > WhatsApp > API Setup
WHATSAPP_TOKEN=your_temporary_or_permanent_token
PHONE_NUMBER_ID=your_phone_number_id

# A password YOU invent. You type the same value into Meta's webhook
# config screen. It just proves the webhook is really yours.
VERIFY_TOKEN=make_up_any_secret_string

# --- Owner (kept for reference; approvals now happen in the dashboard) ---
# Full number, country code, no +, no spaces. e.g. 919876543210
OWNER_NUMBER=91xxxxxxxxxx

# --- LLM providers (fallback chain: Gemini keys, then OpenRouter) ---
# Free Gemini keys from aistudio.google.com. Add as many as you like.
GEMINI_API_KEY=your_gemini_key
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
# Free key from openrouter.ai — final fallback when Gemini quotas run out.
OPENROUTER_API_KEY=

# --- Supabase (database) ---
# Supabase dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
# The service_role key (SECRET — full DB access). Never expose to the browser.
SUPABASE_SERVICE_KEY=your_service_role_key

# --- Firebase Admin (verifies dashboard logins) ---
# Firebase Console > Project Settings > Service accounts > Generate new private key.
# Paste the ENTIRE downloaded JSON on one line (as a string).
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# Port the server listens on
PORT=3000
