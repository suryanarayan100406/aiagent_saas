# --- Meta / WhatsApp Cloud API ---
# From developers.facebook.com > your app > WhatsApp > API Setup
WHATSAPP_TOKEN=your_temporary_or_permanent_token
PHONE_NUMBER_ID=your_phone_number_id

# A password YOU invent. You type the same value into Meta's webhook
# config screen. It just proves the webhook is really yours.
VERIFY_TOKEN=make_up_any_secret_string

# --- Owner (you get pinged for risky messages) ---
# Full number, country code, no +, no spaces. e.g. 919876543210
OWNER_NUMBER=91xxxxxxxxxx

# --- Gemini (free key from aistudio.google.com) ---
GEMINI_API_KEY=your_gemini_key

# Port the server listens on
PORT=3000
